# --- Modal (production) ---
# HTTPS URL of your Modal web endpoint that accepts POST JSON and returns strict JSON.
MODAL_API_URL=

# --- Firebase Admin (server only — never expose private key to the client) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key; on Vercel use real newlines or replace \n in the dashboard
FIREBASE_PRIVATE_KEY=

# --- Abuse / privacy ---
# Random long secret; used to SHA-256 hash visitor IPs before storing (never store raw IPs).
IP_HASH_SALT=

# --- Admin (/admin) ---
ADMIN_PASSWORD=
# Random long secret used to sign the admin session cookie (HMAC-SHA256). Generate e.g. openssl rand -hex 32
ADMIN_SESSION_SECRET=
